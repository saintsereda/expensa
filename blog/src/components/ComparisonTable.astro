---
interface Row {
  feature: string;
  values: string[];
}

interface Props {
  apps: string[];
  rows: Row[];
  highlightColumn?: number;
}

const { apps, rows, highlightColumn = 0 } = Astro.props;

function classify(value: string): string {
  const v = value.toLowerCase().trim();
  if (v === 'yes') return 'cell-yes';
  if (v === 'no') return 'cell-no';
  if (v.startsWith('no ')) return 'cell-no-qualified';
  return 'cell-info';
}
---

<div class="cmp-wrap">
  <div class="cmp-scroll">
    <table class="cmp-table">
      <thead>
        <tr>
          <th class="cmp-feature-col">Feature</th>
          {apps.map((app, i) => (
            <th class={i === highlightColumn ? 'cmp-highlight' : ''}>{app}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td class="cmp-feature-name">{row.feature}</td>
            {row.values.map((value, i) => {
              const cls = `${classify(value)} ${i === highlightColumn ? 'cmp-highlight' : ''}`.trim();
              return <td class={cls}>{value}</td>;
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .cmp-wrap {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-top: 32px;
    margin-bottom: 32px;
    padding: 0 24px;
    box-sizing: border-box;
  }
  .cmp-scroll {
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    -webkit-overflow-scrolling: touch;
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    line-height: 1.4;
    min-width: 760px;
  }
  .cmp-table thead th {
    text-align: left;
    font-weight: 600;
    color: var(--text);
    padding: 14px 16px;
    background: var(--code-bg);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .cmp-table tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    color: var(--text);
    vertical-align: top;
  }
  .cmp-table tbody tr:last-child td {
    border-bottom: none;
  }
  .cmp-table tbody td:last-child,
  .cmp-table thead th:last-child {
    border-right: none;
  }
  .cmp-table thead th {
    border-right: 1px solid var(--border);
  }
  .cmp-table thead th:last-child {
    border-right: none;
  }
  .cmp-feature-col,
  .cmp-feature-name {
    font-weight: 600;
    background: var(--code-bg);
    position: sticky;
    left: 0;
    z-index: 1;
    min-width: 200px;
  }
  .cmp-table tbody .cmp-feature-name {
    color: var(--text);
    opacity: 1;
  }
  .cmp-highlight {
    background: color-mix(in srgb, var(--accent) 8%, var(--bg));
  }
  .cmp-table thead th.cmp-highlight {
    background: color-mix(in srgb, var(--accent) 16%, var(--code-bg));
    color: var(--accent);
  }
  .cell-yes {
    color: rgb(34, 160, 110);
    font-weight: 600;
  }
  [data-theme="dark"] .cell-yes {
    color: rgb(74, 222, 128);
  }
  .cell-no {
    color: var(--muted);
  }
  .cell-no-qualified {
    color: var(--muted);
    font-style: italic;
  }
  .cell-info {
    color: var(--text);
  }
  .cmp-table tbody tr:hover td {
    background: color-mix(in srgb, var(--text) 3%, transparent);
  }
  .cmp-table tbody tr:hover .cmp-feature-name {
    background: color-mix(in srgb, var(--text) 5%, var(--code-bg));
  }
  .cmp-table tbody tr:hover td.cmp-highlight {
    background: color-mix(in srgb, var(--accent) 12%, var(--bg));
  }

  @media (max-width: 768px) {
    .cmp-wrap {
      padding: 0;
    }
    .cmp-scroll {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .cmp-feature-col,
    .cmp-feature-name {
      min-width: 160px;
    }
  }
</style>
