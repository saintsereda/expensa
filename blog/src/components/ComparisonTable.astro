---
interface Row {
  feature: string;
  values: string[];
}

interface Props {
  apps: string[];
  rows: Row[];
  icons?: string[];
  highlightColumn?: number;
  featureLabel?: string;
}

const { apps, rows, icons = [], highlightColumn = 0, featureLabel = 'Feature' } = Astro.props;

type Cell = { kind: 'yes' | 'no' | 'info'; note: string };

function parseCell(value: string): Cell {
  const v = value.trim();
  const lower = v.toLowerCase();
  if (lower === 'yes' || lower === 'так') return { kind: 'yes', note: '' };
  if (lower === 'no' || lower === 'ні') return { kind: 'no', note: '' };
  const yesMatch = v.match(/^(Так|Yes)[\s(,—-]+(.*)$/i);
  if (yesMatch) return { kind: 'yes', note: yesMatch[2].replace(/\)$/, '') };
  const noMatch = v.match(/^(Ні|No)[\s(,—-]+(.*)$/i);
  if (noMatch) return { kind: 'no', note: noMatch[2].replace(/\)$/, '') };
  return { kind: 'info', note: v };
}
---

<div class="cmp-wrap">
  <div class="cmp-scroll">
    <table class="cmp-table">
      <thead>
        <tr>
          <th class="cmp-feature-col">{featureLabel}</th>
          {apps.map((app, i) => (
            <th class={i === highlightColumn ? 'cmp-highlight' : ''}>
              <div class="cmp-app-head">
                {icons[i] && <img class="cmp-app-icon" src={icons[i]} alt={`${app} icon`} width="28" height="28" loading="lazy" />}
                <span>{app}</span>
              </div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td class="cmp-feature-name">{row.feature}</td>
            {row.values.map((value, i) => {
              const cell = parseCell(value);
              const hl = i === highlightColumn ? ' cmp-highlight' : '';
              if (cell.kind === 'yes')
                return (
                  <td class={`cell-yes${hl}`}>
                    <span class="cmp-mark cmp-mark-yes" aria-label="Так">✓</span>
                    {cell.note && <span class="cmp-note">{cell.note}</span>}
                  </td>
                );
              if (cell.kind === 'no')
                return (
                  <td class={`cell-no${hl}`}>
                    <span class="cmp-mark cmp-mark-no" aria-label="Ні">✕</span>
                    {cell.note && <span class="cmp-note">{cell.note}</span>}
                  </td>
                );
              return <td class={`cell-info${hl}`}>{value}</td>;
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .cmp-wrap {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-top: 32px;
    margin-bottom: 32px;
    padding: 0 24px;
    box-sizing: border-box;
  }
  .cmp-scroll {
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    -webkit-overflow-scrolling: touch;
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    line-height: 1.4;
    min-width: 760px;
  }
  .cmp-table thead th {
    text-align: left;
    font-weight: 600;
    color: var(--text);
    padding: 12px 16px;
    background: var(--code-bg);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    vertical-align: bottom;
  }
  .cmp-app-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .cmp-app-icon {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    display: block;
    box-shadow: 0 0 0 1px var(--border);
  }
  .cmp-table tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    color: var(--text);
    vertical-align: top;
  }
  .cmp-table tbody tr:last-child td {
    border-bottom: none;
  }
  .cmp-table tbody td:last-child,
  .cmp-table thead th:last-child {
    border-right: none;
  }
  .cmp-table thead th {
    border-right: 1px solid var(--border);
  }
  .cmp-table thead th:last-child {
    border-right: none;
  }
  .cmp-feature-col,
  .cmp-feature-name {
    font-weight: 600;
    background: var(--code-bg);
    position: sticky;
    left: 0;
    z-index: 1;
    min-width: 200px;
  }
  .cmp-table tbody .cmp-feature-name {
    color: var(--text);
    opacity: 1;
  }
  .cmp-highlight {
    background: color-mix(in srgb, var(--accent) 8%, var(--bg));
  }
  .cmp-table thead th.cmp-highlight {
    background: color-mix(in srgb, var(--accent) 16%, var(--code-bg));
    color: var(--accent);
  }
  .cmp-mark {
    display: inline-block;
    font-weight: 700;
    font-size: 16px;
    line-height: 1;
  }
  .cmp-mark-yes {
    color: rgb(34, 160, 110);
  }
  :global([data-theme="dark"]) .cmp-mark-yes {
    color: rgb(74, 222, 128);
  }
  .cmp-mark-no {
    color: rgb(220, 68, 68);
  }
  :global([data-theme="dark"]) .cmp-mark-no {
    color: rgb(248, 113, 113);
  }
  .cmp-note {
    display: block;
    margin-top: 4px;
    font-size: 12px;
    color: var(--muted);
    font-weight: 400;
  }
  .cell-info {
    color: var(--text);
  }
  .cmp-table tbody tr:hover td {
    background: color-mix(in srgb, var(--text) 3%, transparent);
  }
  .cmp-table tbody tr:hover .cmp-feature-name {
    background: color-mix(in srgb, var(--text) 5%, var(--code-bg));
  }
  .cmp-table tbody tr:hover td.cmp-highlight {
    background: color-mix(in srgb, var(--accent) 12%, var(--bg));
  }

  @media (max-width: 768px) {
    .cmp-wrap {
      padding: 0;
    }
    .cmp-scroll {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .cmp-feature-col,
    .cmp-feature-name {
      min-width: 160px;
    }
  }
</style>
