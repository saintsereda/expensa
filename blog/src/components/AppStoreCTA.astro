---
// Inline mid-post CTA — place anywhere in MDX with <AppStoreCTA />
const APP_STORE_URL = 'https://apps.apple.com/app/expensa/id0000000000'; // TODO: update with real App Store ID
---

<a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="cta-inline">
  <span class="cta-icon">
    <svg width="40" height="40" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="256" height="256" rx="56" fill="#0033FF"/>
      <g clip-path="url(#clip0_cta)">
        <path d="M128 48C168.317 48 201 80.683 201 121H128V48Z" fill="white"/>
        <path d="M91.5 121C91.5 141.158 107.842 157.5 128 157.5C138.24 157.5 147.49 153.285 154.112 146.5L180.5 171.65C167.24 185.4 148.63 194 128 194C87.683 194 55 161.317 55 121H91.5Z" fill="white"/>
      </g>
      <defs>
        <clipPath id="clip0_cta">
          <rect x="55" y="48" width="146" height="146" fill="white"/>
        </clipPath>
      </defs>
    </svg>
  </span>
  <span class="cta-text">
    <strong>Track your expenses automatically</strong>
    <span>Expensa — AI-powered expense tracker for iPhone</span>
  </span>
  <span class="cta-action">Download for free →</span>
</a>

<style>
  .cta-inline {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    margin: 32px 0;
    border: 1px solid rgba(0, 51, 255, 0.3);
    border-radius: 12px;
    background: rgba(0, 51, 255, 0.05);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background 0.15s;
  }
  .cta-inline:hover {
    border-color: rgba(0, 51, 255, 0.6);
    background: rgba(0, 51, 255, 0.09);
  }
  .cta-icon {
    flex-shrink: 0;
    line-height: 0;
  }
  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .cta-text strong {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .cta-text span {
    font-size: 13px;
    color: var(--muted);
  }
  .cta-action {
    font-size: 14px;
    font-weight: 500;
    color: #0033FF;
    white-space: nowrap;
    flex-shrink: 0;
  }
  @media (max-width: 560px) {
    .cta-inline {
      flex-wrap: wrap;
    }
    .cta-action {
      width: 100%;
      padding-left: 38px;
    }
  }
</style>
