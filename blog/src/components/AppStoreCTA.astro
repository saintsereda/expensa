---
// Inline mid-post CTA — place anywhere in MDX with <AppStoreCTA />
const APP_STORE_URL = 'https://apps.apple.com/app/expensa/id0000000000'; // TODO: update with real App Store ID
---

<a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="cta-inline" data-cta-spotlight>
  <span class="cta-glow" />
  <span class="cta-watermark">
    <svg viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M128 -0.000244141C198.692 -0.000244141 256 57.3075 256 128H128V-0.000244141Z" fill="currentColor"/>
      <path d="M63.9992 128C63.9992 163.347 92.6531 192 127.999 192C145.964 192 162.195 184.593 173.818 172.673L220.163 216.807C196.881 240.964 164.2 256.001 127.999 256.001C57.3067 256.001 -0.000976562 198.693 -0.000976562 128H63.9992Z" fill="currentColor"/>
    </svg>
  </span>
  <span class="cta-content">
    <span class="cta-label">Expensa for iPhone</span>
    <span class="cta-headline">Track spending automatically</span>
    <span class="cta-sub">Receipt scanning, budgets, Apple Pay sync — free on the App Store.</span>
  </span>
  <span class="cta-action">
    <span class="cta-action-text">Get the app</span>
    <svg class="cta-action-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 17L17 7M17 7H7M17 7v10"/>
    </svg>
  </span>
</a>

<script>
  document.querySelectorAll('[data-cta-spotlight]').forEach(el => {
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      (el as HTMLElement).style.setProperty('--x', `${x}px`);
      (el as HTMLElement).style.setProperty('--y', `${y}px`);
    });
  });
</script>

<style>
  .cta-inline {
    --x: 50%;
    --y: 50%;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto;
    align-items: center;
    gap: 20px;
    position: relative;
    padding: 28px 32px;
    margin: 40px 0;
    border-radius: 24px;
    overflow: hidden;
    background: color-mix(in srgb, var(--text) 3%, var(--bg));
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.15s;
    isolation: isolate;
  }
  .cta-inline:hover {
    border-color: color-mix(in srgb, var(--text) 20%, transparent);
  }
  .cta-inline:active {
    transform: scale(0.98);
  }

  /* Spotlight glow that follows cursor */
  .cta-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      320px circle at var(--x) var(--y),
      color-mix(in srgb, var(--text) 6%, transparent),
      transparent 70%
    );
    transition: opacity 0.4s;
    z-index: 0;
  }
  .cta-inline:hover .cta-glow {
    opacity: 1;
  }

  /* Oversized Expensa mark — ghosted watermark */
  .cta-watermark {
    position: absolute;
    right: -20px;
    top: 50%;
    transform: translateY(-50%);
    width: 180px;
    height: 180px;
    pointer-events: none;
    color: var(--text);
    opacity: 0.04;
    transition: opacity 0.4s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }
  .cta-inline:hover .cta-watermark {
    opacity: 0.07;
    transform: translateY(-50%) scale(1.05) rotate(-3deg);
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
    z-index: 1;
  }
  .cta-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .cta-headline {
    font-size: 18px;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.2;
  }
  .cta-sub {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    margin-top: 2px;
  }
  .cta-action {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: #0033FF;
    color: #fff;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 550;
    letter-spacing: -0.005em;
    white-space: nowrap;
    transition: box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.15s;
  }
  .cta-inline:hover .cta-action {
    box-shadow: 0 6px 20px -6px rgba(0, 0, 0, 0.3);
  }
  .cta-action-icon {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-inline:hover .cta-action-icon {
    transform: translate(2px, -2px);
  }

  @media (max-width: 560px) {
    .cta-inline {
      grid-template-columns: 1fr;
      padding: 24px;
      gap: 16px;
    }
    .cta-action {
      justify-self: start;
    }
    .cta-watermark {
      width: 140px;
      height: 140px;
      right: -20px;
    }
  }
</style>
