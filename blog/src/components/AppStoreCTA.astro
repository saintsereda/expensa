---
// Inline mid-post CTA — place anywhere in MDX with <AppStoreCTA />
const APP_STORE_URL = 'https://apps.apple.com/app/expensa/id0000000000'; // TODO: update with real App Store ID
---

<a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="cta-inline">
  <span class="cta-icon">📱</span>
  <span class="cta-text">
    <strong>Track your expenses automatically</strong>
    <span>Expensa — AI-powered expense tracker for iPhone</span>
  </span>
  <span class="cta-action">Download for free →</span>
</a>

<style>
  .cta-inline {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    margin: 32px 0;
    border: 1px solid rgba(120, 115, 255, 0.3);
    border-radius: 12px;
    background: rgba(120, 115, 255, 0.05);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background 0.15s;
  }
  .cta-inline:hover {
    border-color: rgba(120, 115, 255, 0.6);
    background: rgba(120, 115, 255, 0.09);
  }
  .cta-icon {
    font-size: 24px;
    flex-shrink: 0;
  }
  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .cta-text strong {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .cta-text span {
    font-size: 13px;
    color: var(--muted);
  }
  .cta-action {
    font-size: 14px;
    font-weight: 500;
    color: rgb(120, 115, 255);
    white-space: nowrap;
    flex-shrink: 0;
  }
  @media (max-width: 560px) {
    .cta-inline {
      flex-wrap: wrap;
    }
    .cta-action {
      width: 100%;
      padding-left: 38px;
    }
  }
</style>
