---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---

<figure class="screenshot-wrap">
  <img src={src} alt={alt} class="screenshot-img" />
  {caption && <figcaption class="screenshot-caption">{caption}</figcaption>}
</figure>

<style>
  .screenshot-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 32px 0;
    gap: 12px;
  }
  .screenshot-img {
    width: 100%;
    max-width: 320px;
    border-radius: 24px;
    border: 1px solid var(--border);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    margin: 0 !important; /* override prose img margin */
  }
  .screenshot-caption {
    font-size: 13px;
    color: var(--muted);
    text-align: center;
  }

  @media (min-width: 600px) {
    .screenshot-img {
      max-width: 360px;
    }
  }
</style>
