---
import BaseLayout from './BaseLayout.astro';
import EndCTA from '../components/EndCTA.astro';
import PostNav from '../components/PostNav.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

interface NavLink {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  titleTag?: string;
  description: string;
  date: Date;
  readingTime: string;
  canonicalUrl?: string;
  lang?: string;
  videoId?: string;
  videoTitle?: string;
  campaign?: string;
  prev?: NavLink;
  next?: NavLink;
}

const { title, titleTag, description, date, readingTime, canonicalUrl, lang, videoId, videoTitle, campaign, prev, next } = Astro.props;

// SEO <title> can be shorter than the on-page H1 to avoid SERP truncation.
const seoTitle = `${titleTag ?? title} — Expensa`;

const APP_STORE_URL = 'https://apps.apple.com/app/expensa-ai-expenses-manager/id6758392205';

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const resolvedUrl = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "url": resolvedUrl,
  "mainEntityOfPage": { "@type": "WebPage", "@id": resolvedUrl },
  "author": {
    "@type": "Person",
    "name": "Andrew Sereda",
    "url": "https://andrewsereda.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Expensa",
    "url": "https://getexpensa.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://getexpensa.com/og-image.png"
    }
  }
};
---

<BaseLayout title={seoTitle} description={description} canonicalUrl={canonicalUrl} lang={lang}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <article class="prose post">
    <header class="post-header">
      <p class="post-meta">{formattedDate} · {readingTime}</p>
      <h1>{title}</h1>
      <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="post-header-cta">
        <span>{lang === 'uk' ? 'Завантажити застосунок' : 'Get the app'}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
      {videoId && (
        <div class="post-header-video">
          <YouTubeEmbed videoId={videoId} title={videoTitle ?? title} />
        </div>
      )}
      <hr />
    </header>

    <slot />

    <PostNav prev={prev} next={next} />

    <EndCTA lang={lang} />
  </article>

  <script is:inline define:vars={{ campaign }}>
    // Attribute every App Store link on this post to the post itself:
    // - Apple App Analytics "Campaigns" reads the ct= token (per-post download attribution)
    // - GA4 records the web-side click so we know click-through per post
    (function () {
      var ct = ('blog_' + (campaign || 'post')).replace(/[^a-zA-Z0-9_-]/g, '_').slice(0, 40);
      document.querySelectorAll('a[href*="apps.apple.com"]').forEach(function (a) {
        try {
          var u = new URL(a.href);
          if (!u.searchParams.has('ct')) u.searchParams.set('ct', ct);
          a.href = u.toString();
        } catch (e) {}
        a.addEventListener('click', function () {
          if (typeof gtag === 'function') {
            gtag('event', 'app_store_click', { campaign: ct, link_url: a.href });
          }
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  .post {
    padding-top: 56px;
    padding-bottom: 0;
  }
  .post-header {
    margin-bottom: 40px;
    text-align: center;
  }
  .post-meta {
    font-size: 14px;
    color: var(--muted);
    margin-top: 0;
    margin-bottom: 16px;
    opacity: 1;
  }
  .post-header-cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 11px 22px;
    margin-bottom: 32px;
    background: #0033FF;
    color: #fff;
    border-radius: 100px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 550;
    letter-spacing: -0.005em;
    transition: box-shadow 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.15s;
  }
  .post-header-cta:hover {
    box-shadow: 0 8px 28px -6px rgba(0, 0, 0, 0.3);
    opacity: 1;
  }
  .post-header-cta:active {
    transform: translateY(1px) scale(0.98);
  }
  .post-header-cta svg {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .post-header-cta:hover svg {
    transform: translate(2px, -2px);
  }
  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0;
  }
</style>
