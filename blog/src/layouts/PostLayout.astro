---
import BaseLayout from './BaseLayout.astro';
import EndCTA from '../components/EndCTA.astro';
import PostNav from '../components/PostNav.astro';

interface NavLink {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  readingTime: string;
  canonicalUrl?: string;
  prev?: NavLink;
  next?: NavLink;
}

const { title, description, date, readingTime, canonicalUrl, prev, next } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const resolvedUrl = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "url": resolvedUrl,
  "mainEntityOfPage": { "@type": "WebPage", "@id": resolvedUrl },
  "author": {
    "@type": "Person",
    "name": "Andrew Sereda",
    "url": "https://andrewsereda.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Expensa",
    "url": "https://expensa.andrewsereda.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://expensa.andrewsereda.com/og-image.png"
    }
  }
};
---

<BaseLayout title={`${title} — Expensa Blog`} description={description} canonicalUrl={canonicalUrl}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <article class="prose post">
    <header class="post-header">
      <h1>{title}</h1>
      <p class="post-meta">{formattedDate} · {readingTime}</p>
      <hr />
    </header>

    <slot />

    <PostNav prev={prev} next={next} />

    <EndCTA />
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: 56px;
    padding-bottom: 0;
  }
  .post-header {
    margin-bottom: 40px;
  }
  .post-meta {
    font-size: 14px;
    color: var(--muted);
    margin-top: 10px;
    margin-bottom: 32px;
    opacity: 1;
  }
  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0;
  }
</style>
